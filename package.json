{
  "name": "discord-drive-uploader",
  "version": "1.0.0",
  "description": "Discord bot that uploads photos and videos from channels to Google Drive folders",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step required for this service'",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint src/",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "keywords": [
    "discord",
    "google-drive",
    "bot",
    "docker"
  ],
  "author": "Tinkertanker",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1",
    "googleapis": "^128.0.0",
    "node-fetch": "^3.3.2",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0"
  }
}